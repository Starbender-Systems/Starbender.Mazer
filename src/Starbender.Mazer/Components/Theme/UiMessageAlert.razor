
@if (IsVisible)
{
    <div class="mudblazor-ui-message-overlay">
        <MudPaper Class="mudblazor-ui-message-card pa-4">
            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <MudText Typo="Typo.h6" Class="mb-2">@Title</MudText>
            }

            @if (ShowMessageIcon)
            {
                <div class="mb-2">
                    <MudIcon Icon="@MessageIcon" Size="Size.Large" Color="@GetColor(MessageType)" />
                </div>
            }

            @if (!IsMessageHtmlMarkup)
            {
                <MudText Typo="Typo.body1">@Message</MudText>
            }
            else
            {
                <div>@((MarkupString)Message)</div>
            }

            <div class="d-flex justify-end mt-4">
                @if (IsConfirmation)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="OnCancelClicked">@CancelButtonText</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnConfirmClicked">@ConfirmButtonText</MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnOkClicked">@OkButtonText</MudButton>
                }
            </div>
        </MudPaper>
    </div>
}

<style>
    .mudblazor-ui-message-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.48);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .mudblazor-ui-message-card {
        width: min(560px, 100%);
    }
</style>
