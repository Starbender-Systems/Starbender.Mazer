@using Starbender.Mazer.Components
@using Volo.Abp.Ui.LayoutHooks
@using Volo.Abp.AspNetCore.Components.Web.Theming.Components.LayoutHooks
@using Volo.Abp.AspNetCore.Components.Web.Theming.Components
@using Volo.Abp.AspNetCore.Components.Web.Theming.Layout
@using MudBlazor

@inherits LayoutComponentBase

<MudThemeProvider Theme="@ThemeManager.Theme" IsDarkMode="@ThemeManager.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    @if (!IsThemeReady)
    {
        <div class="mud-theme-startup-overlay">
            <MudProgressCircular Indeterminate="true" />
        </div>
    }
    else
    {
        <MudAppBar Elevation="10" Dense="true" Fixed="true" Class="appbar-force-text">
            <MudIconButton Color="@Color.Inherit" 
                aria-label="Toggle navigation menu"
                OnClick="ToggleDrawer" 
                Icon="@Icons.Material.Outlined.Menu" />

            <Branding />
            <MudSpacer />
            <NavToolbar />
        </MudAppBar>

        <MudDrawer @bind-Open="IsDrawerOpen"
                   Elevation="1"
                   ClipMode="DrawerClipMode.Always"
                   Variant="DrawerVariant.Responsive"
                   Class="pa-2">
            <NavMenu />
        </MudDrawer>

        <MudMainContent>
            <MudContainer Class="mt-4">
                <PageAlert />
                <LayoutHook Name="@LayoutHooks.Body.First" Layout="@StandardLayouts.Application" />
                @Body
                <LayoutHook Name="@LayoutHooks.Body.Last" Layout="@StandardLayouts.Application" />
                <DynamicLayoutComponent />
                <UiMessageAlert />
                <UiNotificationAlert />
                <UiPageProgress />
            </MudContainer>
        </MudMainContent>
    }
</MudLayout>
