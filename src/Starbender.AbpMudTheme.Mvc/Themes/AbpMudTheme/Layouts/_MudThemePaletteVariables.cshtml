@using Microsoft.Extensions.Logging
@using Microsoft.Extensions.Options
@using MudBlazor
@using Starbender.AbpMudTheme.Mvc
@using Starbender.AbpMudTheme.Mvc.Themes.AbpMudTheme.Styling
@inject IOptionsMonitor<MudTheme> MudThemeOptions
@inject ILogger<AbpMudThemeMvcModule> Logger
@{
    var paletteVariablesCss = MudThemeCssVariablesBuilder.Build(MudThemeOptions.CurrentValue);
    Logger.LogDebug(paletteVariablesCss);
}
<style id="abp-mud-theme-palette-variables">
@Html.Raw(paletteVariablesCss)
</style>
