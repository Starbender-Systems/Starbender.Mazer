@using Microsoft.Extensions.Options
@using Starbender.Mazer.Mvc.Bundling
@using Volo.Abp.AspNetCore.Mvc.UI.Bundling.TagHelpers
@using Volo.Abp.AspNetCore.Mvc.UI.Components.LayoutHook
@using Volo.Abp.AspNetCore.Mvc.UI.Layout
@using Starbender.Mazer.Mvc.Themes.Mazer.Components.ContentTitle
@using Starbender.Mazer.Mvc.Themes.Mazer.Components.Brand
@using Starbender.Mazer.Mvc.Themes.Mazer.Components.Menu
@using Starbender.Mazer.Mvc.Themes.Mazer.Components.PageAlerts
@using Starbender.Mazer.Mvc.Themes.Mazer.Components.Toolbar
@using Volo.Abp.AspNetCore.Mvc.UI.Theming
@using Volo.Abp.AspNetCore.Mvc.UI.Widgets.Components.WidgetScripts
@using Volo.Abp.AspNetCore.Mvc.UI.Widgets.Components.WidgetStyles
@using Volo.Abp.Localization
@using Volo.Abp.Ui.Branding
@using Volo.Abp.Ui.LayoutHooks
@inject IBrandingProvider BrandingProvider
@inject IPageLayout PageLayout
@inject IOptions<AbpThemingOptions> ThemingOptions

@{
    Layout = null;
    var containerClass = ViewBag.FluidLayout == true ? "container-fluid" : "container"; //TODO: Better and type-safe options

    var pageTitle = ViewBag.Title == null ? BrandingProvider.AppName : ViewBag.Title; //TODO: Discard to get from Title

    if (PageLayout.Content.Title != null)
    {
        if (!string.IsNullOrWhiteSpace(pageTitle))
        {
            pageTitle = " | " + pageTitle;
        }

        pageTitle = PageLayout.Content.Title + pageTitle;
    }

    var rtl = CultureHelper.IsRtl ? "rtl" : string.Empty;
}

<!DOCTYPE html>

<html lang="@CultureInfo.CurrentCulture.Name" dir="@rtl" class="abp-theme-init-pending">
<head>
    @await Component.InvokeLayoutHookAsync(LayoutHooks.Head.First, StandardLayouts.Application)

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link rel="icon" href="~/favicon.ico" type="image/x-icon">
    @if (!ThemingOptions.Value.BaseUrl.IsNullOrWhiteSpace())
    {
        <base href="@ThemingOptions.Value.BaseUrl" />
    }

    <title>@pageTitle</title>

    <style>
        html.abp-theme-init-pending body {
            visibility: hidden;
        }
    </style>
    <noscript>
        <style>
            html.abp-theme-init-pending body {
                visibility: visible;
            }
        </style>
    </noscript>
    <script>
        (function () {
            var root = document.documentElement;
            var storageKey = "abpMudBlazorTheme.state";
            var isDarkMode = false;

            try {
                var raw = window.localStorage.getItem(storageKey);
                if (raw) {
                    var state = JSON.parse(raw);
                    if (state && typeof state.isDarkMode === "boolean") {
                        isDarkMode = state.isDarkMode;
                    } else {
                        isDarkMode = !!(window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches);
                    }
                } else {
                    isDarkMode = !!(window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches);
                }
            } catch (error) {
                isDarkMode = !!(window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches);
            }

            var mode = isDarkMode ? "dark" : "light";
            root.setAttribute("data-bs-theme", mode);

            if (document.body) {
                document.body.setAttribute("data-bs-theme", mode);
            } else {
                document.addEventListener("DOMContentLoaded", function () {
                    if (document.body) {
                        document.body.setAttribute("data-bs-theme", mode);
                    }
                }, { once: true });
            }

            root.classList.remove("abp-theme-init-pending");
        })();
    </script>

    <abp-style-bundle name="@MazerBundles.Styles.Global" />
    @await Html.PartialAsync("~/Themes/Mazer/Layouts/_MudThemePaletteVariables.cshtml")

    @await Component.InvokeAsync(typeof(WidgetStylesViewComponent))

    @await RenderSectionAsync("styles", false)

    @await Component.InvokeLayoutHookAsync(LayoutHooks.Head.Last, StandardLayouts.Application)
</head>
<body class="abp-application-layout @rtl">
    @await Component.InvokeLayoutHookAsync(LayoutHooks.Body.First, StandardLayouts.Application)

    <div class="abp-mud-shell">
        <header class="abp-mud-appbar">
            <div class="abp-mud-appbar-content">
                <button class="abp-mud-drawer-toggle"
                        type="button"
                        aria-label="Toggle navigation menu"
                        aria-controls="abp-mud-drawer"
                        aria-expanded="true">
                    <span class="abp-mud-drawer-toggle-icon" aria-hidden="true">&#9776;</span>
                </button>

                <div class="abp-mud-brand">
                    @(await Component.InvokeAsync<MainNavbarBrandViewComponent>())
                </div>

                <div class="abp-mud-appbar-spacer"></div>

                <ul class="navbar-nav flex-row align-items-center" id="main-navbar-tools">
                    @(await Component.InvokeAsync<MainNavbarToolbarViewComponent>())
                </ul>
            </div>
        </header>

        <div class="abp-mud-layout">
            <aside id="abp-mud-drawer" class="abp-mud-drawer">
                <nav class="navbar p-0">
                    <ul class="navbar-nav flex-column w-100">
                        @(await Component.InvokeAsync<MainNavbarMenuViewComponent>())
                    </ul>
                </nav>
            </aside>

            <main class="abp-mud-main">
                <div class="@containerClass mt-4">
                    @(await Component.InvokeAsync<PageAlertsViewComponent>())
                    <div id="AbpContentToolbar">
                        <div class="row mb-2">
                            @(await Component.InvokeAsync<ContentTitleViewComponent>())
                            <div class="col">
                                <div class="text-end">
                                    @await RenderSectionAsync("content_toolbar", false)
                                </div>
                            </div>
                        </div>
                    </div>
                    @await Component.InvokeLayoutHookAsync(LayoutHooks.PageContent.First, StandardLayouts.Application)
                    @RenderBody()
                    @await Component.InvokeLayoutHookAsync(LayoutHooks.PageContent.Last, StandardLayouts.Application)
                </div>
            </main>
        </div>
    </div>

    <abp-script-bundle name="@MazerBundles.Scripts.Global" />

    <script src="~/Abp/ApplicationLocalizationScript?cultureName=@CultureInfo.CurrentUICulture.Name"></script>
    <script src="~/Abp/ApplicationConfigurationScript"></script>
    <script src="~/Abp/ServiceProxyScript"></script>

    @await Component.InvokeAsync(typeof(WidgetScriptsViewComponent))

    @await RenderSectionAsync("scripts", false)

    @await Component.InvokeLayoutHookAsync(LayoutHooks.Body.Last, StandardLayouts.Application)
</body>
</html>
