
@if (Visible)
{
    <MudProgressLinear Class="mudblazor-ui-page-progress"
                       Color="@Color"
                       Indeterminate="@(!Percentage.HasValue)"
                       Value="@Percentage.GetValueOrDefault()" />
}

<style>
    .mudblazor-ui-page-progress {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 2200;
    }
</style>
