
@using Volo.Abp.Users
@using Volo.Abp.MultiTenancy
@using Microsoft.Extensions.Localization
@using global::Localization.Resources.AbpUi
@using global::MudBlazor

@inject ICurrentUser CurrentUser
@inject ICurrentTenant CurrentTenant
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject IStringLocalizer<AbpUiResource> L

<AuthorizeView>
    <Authorized>
        <MudMenu Dense="true">
            <ActivatorContent>
                <MudButton Class="abp-appbar-text" Color="Color.Inherit">
                    @if (CurrentTenant.Name != null)
                    {
                        <span><i>@CurrentTenant.Name</i>\@CurrentUser.UserName</span>
                    }
                    else
                    {
                        <span>@CurrentUser.UserName</span>
                    }
                </MudButton>
            </ActivatorContent>
            <ChildContent>
                @if (Menu != null)
                {
                    @foreach (var menuItem in Menu.Items)
                    {
                        <MudMenuItem OnClick="@(() => NavigateToAsync(menuItem.Url, menuItem.Target))">
                            @menuItem.DisplayName
                        </MudMenuItem>
                    }
                }
            </ChildContent>
        </MudMenu>
    </Authorized>
    <NotAuthorized>
        <MudButton Href="Account/Login" Class="abp-appbar-text" Color="Color.Inherit">@L["Login"]</MudButton>
    </NotAuthorized>
</AuthorizeView>

